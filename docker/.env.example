# ─── InternHub Production Environment Variables ──────────────
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control

# Server
PORT=5000
NODE_ENV=production

# Database (AWS RDS MySQL)
DB_HOST=internhub.co96g4i46lwk.us-east-1.rds.amazonaws.com
DB_USER=Internhub_admin
DB_PASSWORD=your_rds_password_here
DB_NAME=internhub_db
DB_PORT=3306

# Authentication
JWT_SECRET=your_production_secret_key_here
JWT_EXPIRES_IN=24h
